  function updateClock() {
    const now = new Date();
    const opts = { weekday:'long', month:'long', day:'numeric' };
    document.querySelector('.header-date').textContent = now.toLocaleDateString('en-US', opts);
  }
  updateClock();

  // ── NAV TABS ──
  document.querySelectorAll('.nav-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
    });
  });

  // ── CATEGORY COLOR MAP ──
  const catColors = {
    'LDRC':    { bg: 'var(--gold-light)',  text: 'var(--gold)' },
    'Grants':  { bg: 'var(--green-light)', text: 'var(--green)' },
    'Realty':  { bg: '#f4f2ee',            text: '#8a8078' },
    'Jane':    { bg: 'var(--green-light)', text: 'var(--green-mid)' },
    'Urgent':  { bg: 'var(--red-light)',   text: 'var(--red)' },
    'Personal':{ bg: '#f0eaf8',            text: '#7a5a9a' },
  };

  function tagStyle(cat) {
    const c = catColors[cat] || { bg: '#f0f0ee', text: '#888' };
    return `background:${c.bg};color:${c.text};`;
  }

  function dotColor(cat, priority) {
    if (priority === 'urgent' || priority === 'high') return 'var(--red)';
    const c = catColors[cat];
    return c ? c.text : '#8a8078';
  }

  // ── RENDER TASKS ──
  function renderTasks(tasks) {
    const body = document.querySelector('.tasks-body');
    if (!tasks || tasks.length === 0) {
      body.innerHTML = '<div style="padding:20px 18px;font-size:13px;color:var(--text-faint);font-style:italic;">No tasks found.</div>';
      return;
    }

    const priority = tasks.filter(t => t.priority === 'urgent' || t.priority === 'high');
    const rest     = tasks.filter(t => t.priority !== 'urgent' && t.priority !== 'high');

    let html = '';

    if (priority.length) {
      html += `<div class="task-group-label">Priority</div>`;
      priority.forEach(t => html += taskHTML(t));
    }
    if (rest.length) {
      html += `<div class="task-group-label">This Week</div>`;
      rest.forEach(t => html += taskHTML(t));
    }

    body.innerHTML = html;

    // Update metrics
    const openCount = tasks.filter(t => !t.completed).length;
    const urgentCount = tasks.filter(t => (t.priority === 'urgent' || t.priority === 'high') && !t.completed).length;
    document.querySelector('.metric-tasks-count').textContent = openCount;
    document.querySelector('.metric-tasks-badge').textContent = urgentCount + ' urgent';

    attachTaskHandlers();
  }

  function taskHTML(t) {
    const cat = t.category || t.tag || 'LDRC';
    const isUrgent = t.priority === 'urgent' || t.priority === 'high';
    const dc = dotColor(cat, t.priority);
    return `
      <div class="task" data-id="${t.id}" data-completed="${t.completed || false}">
        <div class="task-check" style="${t.completed ? 'background:var(--green);border-color:var(--green);' : ''}">
          ${t.completed ? '<svg width="10" height="8" viewBox="0 0 10 8" fill="none"><path d="M1 4L3.5 6.5L9 1" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>' : ''}
        </div>
        <div class="task-dot" style="background:${dc};"></div>
        <div class="task-text ${isUrgent ? 'urgent' : ''}" style="${t.completed ? 'text-decoration:line-through;opacity:0.45;' : ''}">${t.title || t.task || ''}</div>
        <div class="task-tag" style="${tagStyle(cat)}">${cat}</div>
      </div>`;
  }

  function attachTaskHandlers() {
    document.querySelectorAll('.task').forEach(task => {
      task.addEventListener('click', async () => {
        const id = task.dataset.id;
        const completed = task.dataset.completed === 'true';
        const newVal = !completed;

        // Optimistic UI
        const check = task.querySelector('.task-check');
        const text  = task.querySelector('.task-text');
        task.dataset.completed = newVal;
        if (newVal) {
          check.style.background = 'var(--green)';
          check.style.borderColor = 'var(--green)';
          check.innerHTML = '<svg width="10" height="8" viewBox="0 0 10 8" fill="none"><path d="M1 4L3.5 6.5L9 1" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>';
          text.style.textDecoration = 'line-through';
          text.style.opacity = '0.45';
        } else {
          check.style.background = '';
          check.style.borderColor = '';
          check.innerHTML = '';
          text.style.textDecoration = '';
          text.style.opacity = '';
        }

        // Persist to Supabase
        await db.from('tasks').update({ completed: newVal }).eq('id', id);
      });
    });
  }

  // ── RENDER EVENTS ──
  function renderEvents(events) {
    const body = document.querySelector('.briefing-events');
    if (!events || events.length === 0) {
      body.innerHTML = '<div style="font-size:12px;color:var(--text-faint);font-style:italic;">No upcoming events.</div>';
      return;
    }
    body.innerHTML = events.slice(0, 4).map(e => {
      const d = e.date || e.start_date || e.event_date || '';
      const dateStr = d ? new Date(d).toLocaleDateString('en-US', { weekday:'short', month:'short', day:'numeric' }) : '';
      const isUrgent = e.urgent || false;
      return `
        <div class="briefing-event">
          <div class="event-dot" style="background:${isUrgent ? 'var(--red)' : 'var(--green)'};"></div>
          <div>
            <div>${e.title || e.name || ''}</div>
            <div class="event-meta" style="${isUrgent ? 'color:var(--red);' : ''}">${dateStr}${e.time ? ' · ' + e.time : ''}</div>
          </div>
        </div>`;
    }).join('');
  }

  // ── RENDER LOGS ──
  function renderLogs(logs) {
    const body = document.querySelector('.log-body');
    if (!logs || logs.length === 0) {
      body.innerHTML = '<div style="padding:16px 18px;font-size:12px;color:var(--text-faint);font-style:italic;">No activity yet.</div>';
      return;
    }
    body.innerHTML = logs.slice(0, 5).map(l => {
      const d = l.created_at || l.date || '';
      const timeStr = d ? formatLogTime(new Date(d)) : '';
      return `
        <div class="log-item">
          <div class="log-time">${timeStr}</div>
          <div>${l.content || l.note || l.message || l.title || ''}</div>
        </div>`;
    }).join('');
  }

  function formatLogTime(date) {
    const now = new Date();
    const diff = now - date;
    const days = Math.floor(diff / 86400000);
    if (days === 0) return date.toLocaleTimeString('en-US', { hour:'numeric', minute:'2-digit' });
    if (days === 1) return 'Yesterday';
    if (days < 7)  return date.toLocaleDateString('en-US', { weekday:'short' });
    return date.toLocaleDateString('en-US', { month:'short', day:'numeric' });
  }

  // ── RENDER GRANTS ──
  function renderGrants(grants) {
    const body = document.querySelector('.grant-body');
    if (!grants || grants.length === 0) {
      body.innerHTML = '<div style="padding:16px 18px;font-size:13px;color:var(--text-faint);font-style:italic;">No grants tracked yet.</div>';
      // Update metric
      document.querySelector('.metric-grants-count').textContent = '0';
      return;
    }
    document.querySelector('.metric-grants-count').textContent = grants.length;

    const icons = ['📱','🏛️','🌱','💼','🏗️','🌿'];
    body.innerHTML = grants.slice(0, 4).map((g, i) => {
      const deadline = g.deadline || g.due_date || g.close_date || '';
      const daysLeft = deadline ? Math.ceil((new Date(deadline) - new Date()) / 86400000) : null;
      const soon = daysLeft !== null && daysLeft <= 7;
      const deadlineStr = deadline
        ? (soon ? `Due in ${daysLeft} day${daysLeft !== 1 ? 's' : ''}` : `Due ${new Date(deadline).toLocaleDateString('en-US', { month:'short', day:'numeric' })}`)
        : '';
      const amount = g.amount ? '$' + Number(g.amount).toLocaleString() : '';
      return `
        <div class="grant-item">
          <div class="grant-icon">${icons[i % icons.length]}</div>
          <div>
            <div class="grant-name">${g.name || g.title || ''}</div>
            <div class="grant-org">${g.organization || g.org || g.funder || ''}</div>
          </div>
          <div class="grant-amount">
            <div class="grant-amount-val">${amount}</div>
            <div class="grant-deadline ${soon ? 'soon' : ''}">${deadlineStr}</div>
          </div>
        </div>`;
    }).join('');
  }

  // ── LOADING STATES ──
  function setLoading(selector, msg = 'Loading…') {
    const el = document.querySelector(selector);
    if (el) el.innerHTML = `<div style="padding:16px 18px;font-size:12px;color:var(--text-faint);font-style:italic;">${msg}</div>`;
  }

  function setError(selector, err) {
    const el = document.querySelector(selector);
    if (el) el.innerHTML = `<div style="padding:16px 18px;font-size:11px;color:var(--red);font-style:italic;">⚠ ${err}</div>`;
  }

  // ── LOAD ALL DATA ──
  async function loadAll() {
    setLoading('.tasks-body', 'Loading tasks…');
    setLoading('.briefing-events', 'Loading events…');
    setLoading('.log-body', 'Loading activity…');
    setLoading('.grant-body', 'Loading grants…');

    const today = new Date().toISOString().split('T')[0];

    const [tasksRes, eventsRes, logsRes, grantsRes] = await Promise.all([
      db.from('tasks').select('*').eq('completed', false).order('created_at', { ascending: false }).limit(20),
      db.from('events').select('*').gte('date', today).order('date', { ascending: true }).limit(5),
      db.from('logs').select('*').order('created_at', { ascending: false }).limit(5),
      db.from('grants').select('*').order('deadline', { ascending: true }).limit(4),
    ]);

    if (tasksRes.error)  setError('.tasks-body',   tasksRes.error.message);
    else                 renderTasks(tasksRes.data);

    if (eventsRes.error) setError('.briefing-events', eventsRes.error.message);
    else                 renderEvents(eventsRes.data);

    if (logsRes.error)   setError('.log-body',     logsRes.error.message);
    else                 renderLogs(logsRes.data);

    if (grantsRes.error) setError('.grant-body',   grantsRes.error.message);
    else                 renderGrants(grantsRes.data);
  }

  loadAll();

  // ── REALTIME: tasks ──
  db.channel('tasks-changes')
    .on('postgres_changes', { event: '*', schema: 'public', table: 'tasks' }, () => {
      db.from('tasks').select('*').eq('completed', false).order('created_at', { ascending: false }).limit(20)
        .then(({ data }) => { if (data) renderTasks(data); });
    })
    .subscribe();

</script>

</body>
</html>
