<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Jane — Command Center</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Lato:wght@300;400;700;900&display=swap" rel="stylesheet">
<style>

/* ── TOKENS ── */
:root {
  --bg:          #edeae4;
  --surface:     #f4f1eb;
  --card:        #faf8f4;
  --border:      rgba(100,90,80,0.14);
  --border-med:  rgba(100,90,80,0.22);
  --green:       #2d5a3d;
  --green-light: #eef4f0;
  --green-mid:   #4a7a5a;
  --gold:        #c8920a;
  --gold-light:  #fdf5e0;
  --red:         #c84040;
  --red-light:   #fdeaea;
  --text-h:      #1e1c18;
  --text:        #3e3830;
  --text-muted:  #7a7268;
  --text-faint:  #a09a92;
  --nav-h:       52px;
  --radius:      12px;
}

* { margin:0; padding:0; box-sizing:border-box; }

body {
  font-family: 'Lato', sans-serif;
  background: var(--bg);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  animation: bodyFade 0.5s ease forwards;
}

@keyframes bodyFade {
  from { opacity:0; }
  to   { opacity:1; }
}

/* ══ HEADER ══ */
.header {
  background: var(--surface);
  border-bottom: 2px solid var(--green);
  padding: 20px 32px 16px;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  animation: slideDown 0.4s ease forwards;
}

@keyframes slideDown {
  from { opacity:0; transform:translateY(-12px); }
  to   { opacity:1; transform:translateY(0); }
}

.header-left { display:flex; flex-direction:column; gap:4px; }

.header-eyebrow {
  font-family: 'Lato', sans-serif;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 3.5px;
  text-transform: uppercase;
  color: var(--green);
}

.header-title {
  font-family: 'Playfair Display', serif;
  font-size: 28px;
  font-weight: 400;
  color: var(--text-h);
  line-height: 1.1;
}

.header-title em {
  font-style: italic;
  color: var(--gold);
}

.header-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4px;
}

.header-date {
  font-family: 'Playfair Display', serif;
  font-style: italic;
  font-size: 14px;
  color: var(--text-muted);
}

.header-status {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  font-weight: 700;
  color: var(--green);
  letter-spacing: 0.5px;
}

.status-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--green);
  animation: pulse 2.5s ease-in-out infinite;
}

@keyframes pulse {
  0%,100% { opacity:1; transform:scale(1); }
  50%      { opacity:0.5; transform:scale(0.85); }
}

/* ══ NAV ══ */
.nav {
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  display: flex;
  padding: 0 28px;
  gap: 0;
  animation: slideDown 0.4s 0.05s ease both;
}

.nav-tab {
  font-family: 'Lato', sans-serif;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--text-faint);
  padding: 13px 16px;
  border-bottom: 2px solid transparent;
  cursor: pointer;
  transition: color 0.2s, border-color 0.2s;
  margin-bottom: -1px;
}

.nav-tab:hover { color: var(--green-mid); }

.nav-tab.active {
  color: var(--green);
  border-bottom-color: var(--green);
}

/* ══ BODY ══ */
.body {
  flex: 1;
  padding: 24px 28px;
  display: grid;
  grid-template-columns: 1fr 340px;
  grid-template-rows: auto auto 1fr;
  gap: 18px;
  animation: fadeUp 0.4s 0.1s ease both;
}

@keyframes fadeUp {
  from { opacity:0; transform:translateY(10px); }
  to   { opacity:1; transform:translateY(0); }
}

/* ══ CARDS ══ */
.card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
}

.card-header {
  padding: 14px 18px 12px;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-title {
  font-family: 'Lato', sans-serif;
  font-size: 10px;
  font-weight: 900;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--text-muted);
  display: flex;
  align-items: center;
  gap: 8px;
}

.card-title::before {
  content: '';
  display: inline-block;
  width: 3px;
  height: 14px;
  background: var(--green);
  border-radius: 3px;
}

.card-action {
  font-size: 10px;
  font-weight: 700;
  color: var(--green);
  letter-spacing: 0.5px;
  cursor: pointer;
  opacity: 0.7;
  transition: opacity 0.2s;
}
.card-action:hover { opacity: 1; }

/* ══ TASKS ══ */
.tasks-card { grid-column: 1; grid-row: 1 / 3; }

.tasks-body { padding: 6px 0; }

.task-group-label {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--text-faint);
  padding: 10px 18px 6px;
}

.task {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 18px;
  border-bottom: 1px solid var(--border);
  cursor: pointer;
  transition: background 0.15s;
}

.task:hover { background: rgba(45,90,61,0.04); }
.task:last-child { border-bottom: none; }

.task-check {
  width: 16px;
  height: 16px;
  border-radius: 4px;
  border: 1.5px solid var(--border-med);
  flex-shrink: 0;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
}

.task:hover .task-check {
  border-color: var(--green);
}

.task-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}

.task-text {
  flex: 1;
  font-size: 13px;
  font-weight: 400;
  color: var(--text);
  line-height: 1.3;
}

.task-text.urgent {
  font-weight: 700;
}

.task-tag {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.5px;
  padding: 3px 9px;
  border-radius: 20px;
  white-space: nowrap;
}

.task-priority {
  font-size: 9px;
  font-weight: 700;
  color: var(--text-faint);
  letter-spacing: 0.3px;
}

/* ══ JANE BRIEFING ══ */
.briefing-card { grid-column: 2; grid-row: 1; }

.briefing-body { padding: 16px 18px 18px; }

.briefing-quote {
  font-family: 'Playfair Display', serif;
  font-style: italic;
  font-size: 13px;
  color: var(--green);
  line-height: 1.75;
  border-left: 3px solid var(--green);
  padding-left: 14px;
  margin-bottom: 16px;
}

.briefing-divider {
  border: none;
  border-top: 1px solid var(--border);
  margin: 0 0 14px;
}

.briefing-section-label {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--text-faint);
  margin-bottom: 10px;
}

.briefing-event {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 6px 0;
  font-size: 12px;
  color: var(--text);
  line-height: 1.4;
  border-bottom: 1px solid var(--border);
}

.briefing-event:last-child { border-bottom: none; }

.event-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--green);
  margin-top: 5px;
  flex-shrink: 0;
}

.event-meta {
  font-size: 10px;
  color: var(--text-faint);
  font-weight: 700;
  margin-top: 1px;
}

/* ══ METRICS ROW ══ */
.metrics-row {
  grid-column: 2;
  grid-row: 2;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.metric-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 14px 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.metric-label {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--text-faint);
  margin-bottom: 4px;
}

.metric-value {
  font-family: 'Playfair Display', serif;
  font-size: 26px;
  font-weight: 600;
  color: var(--text-h);
  line-height: 1;
}

.metric-value span {
  font-size: 13px;
  color: var(--text-muted);
  font-family: 'Lato', sans-serif;
  font-weight: 400;
}

.metric-badge {
  font-size: 10px;
  font-weight: 700;
  padding: 4px 10px;
  border-radius: 20px;
}

/* ══ GRANT CARD ══ */
.grant-card {
  grid-column: 1;
  grid-row: 3;
  align-self: start;
}

.grant-body { padding: 14px 0; }

.grant-item {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 10px 18px;
  border-bottom: 1px solid var(--border);
  transition: background 0.15s;
  cursor: pointer;
}

.grant-item:hover { background: rgba(45,90,61,0.04); }
.grant-item:last-child { border-bottom: none; }

.grant-icon {
  width: 36px;
  height: 36px;
  border-radius: 8px;
  background: var(--green-light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  flex-shrink: 0;
}

.grant-name {
  font-size: 13px;
  font-weight: 700;
  color: var(--text-h);
  margin-bottom: 2px;
}

.grant-org {
  font-size: 11px;
  color: var(--text-muted);
}

.grant-amount {
  margin-left: auto;
  text-align: right;
}

.grant-amount-val {
  font-family: 'Playfair Display', serif;
  font-size: 15px;
  font-weight: 600;
  color: var(--green);
}

.grant-deadline {
  font-size: 10px;
  color: var(--text-faint);
  margin-top: 2px;
}

.grant-deadline.soon { color: var(--red); font-weight: 700; }

/* ══ QUICK LOG ══ */
.log-card {
  grid-column: 2;
  grid-row: 3;
  align-self: start;
}

.log-body { padding: 8px 0; }

.log-item {
  display: flex;
  gap: 12px;
  padding: 9px 18px;
  border-bottom: 1px solid var(--border);
  font-size: 12px;
  color: var(--text);
  line-height: 1.4;
}

.log-item:last-child { border-bottom: none; }

.log-time {
  font-size: 10px;
  font-weight: 700;
  color: var(--text-faint);
  white-space: nowrap;
  margin-top: 2px;
  min-width: 44px;
}

/* ══ JANE BAR ══ */
.jane-bar {
  background: var(--surface);
  border-top: 1px solid var(--border-med);
  padding: 14px 28px;
  display: flex;
  align-items: center;
  gap: 12px;
  animation: slideUp 0.4s 0.15s ease both;
}

@keyframes slideUp {
  from { opacity:0; transform:translateY(12px); }
  to   { opacity:1; transform:translateY(0); }
}

.jane-avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: var(--green);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Playfair Display', serif;
  font-style: italic;
  font-size: 14px;
  color: #fff;
  flex-shrink: 0;
}

.jane-input-wrap {
  flex: 1;
  position: relative;
}

.jane-input {
  width: 100%;
  background: var(--card);
  border: 1px solid var(--border-med);
  border-radius: 24px;
  padding: 9px 18px;
  font-family: 'Playfair Display', serif;
  font-style: italic;
  font-size: 13px;
  color: var(--text-muted);
  outline: none;
  transition: border-color 0.2s, box-shadow 0.2s;
}

.jane-input:focus {
  border-color: var(--green);
  box-shadow: 0 0 0 3px rgba(45,90,61,0.1);
  color: var(--text);
}

.jane-input::placeholder { color: var(--text-faint); }

.jane-send {
  background: var(--green);
  color: #fff;
  border: none;
  border-radius: 24px;
  padding: 9px 22px;
  font-family: 'Lato', sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.2s, transform 0.15s;
}

.jane-send:hover {
  background: #1f4029;
  transform: translateY(-1px);
}

.jane-send:active { transform: translateY(0); }

.jane-shortcuts {
  display: flex;
  gap: 8px;
}

.shortcut-chip {
  font-size: 10px;
  font-weight: 700;
  color: var(--green);
  background: var(--green-light);
  border: 1px solid rgba(45,90,61,0.18);
  border-radius: 14px;
  padding: 5px 12px;
  cursor: pointer;
  white-space: nowrap;
  letter-spacing: 0.3px;
  transition: all 0.2s;
}

.shortcut-chip:hover {
  background: var(--green);
  color: #fff;
  border-color: var(--green);
}

</style>
</head>
